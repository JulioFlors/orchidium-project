{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build",
        "db:generate"
      ],
      "cache": false,
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ],
      "env": [
        "AUTH_GOOGLE_ID",
        "AUTH_GOOGLE_SECRET",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "DATABASE_URL_UNPOOLED",
        "DATABASE_URL",
        "INFLUX_BUCKET",
        "INFLUX_TOKEN",
        "INFLUX_URL",
        "NEXT_PUBLIC_MQTT_BASE_TOPIC",
        "NEXT_PUBLIC_MQTT_BROKER",
        "NEXT_PUBLIC_MQTT_PASSWORD",
        "NEXT_PUBLIC_MQTT_PORT",
        "NEXT_PUBLIC_MQTT_PROTOCOL",
        "NEXT_PUBLIC_MQTT_USERNAME"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "dev": {
      "dependsOn": [
        "^db:generate"
      ],
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": [
        "^build"
      ],
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "inputs": [
        "packages/database/prisma/schema.prisma"
      ],
      "outputs": [
        "packages/database/src/generated/prisma/**"
      ],
      "cache": false,
      "env": [
        "DATABASE_URL"
      ]
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "db:deploy": {
      "cache": false
    }
  }
}