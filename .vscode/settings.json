{
	"typescript.tsdk": "node_modules\\typescript\\lib",
	"typescript.enablePromptUseWorkspaceTsdk": true,

	// ── Formateo: ESLint como ÚNICO mecanismo ─────────────────
	// formatOnSave DESACTIVADO: evita que el defaultFormatter corra al guardar.
	// El formateo lo maneja source.fixAll.eslint (que incluye Prettier).
	"editor.formatOnSave": false,
	"editor.codeActionsOnSave": {
		"source.fixAll.eslint": "always",
		"source.fixAll.markdownlint": "always",
		"source.organizeImports": "never"
	},

	"eslint.validate": [
		"javascript",
		"javascriptreact",
		"typescript",
		"typescriptreact",
		"markdown"
	],

	// defaultFormatter = ESLint para JS/TS (solo se usa con Format Document manual)
	"[javascript]": { "editor.defaultFormatter": "dbaeumer.vscode-eslint" },
	"[javascriptreact]": { "editor.defaultFormatter": "dbaeumer.vscode-eslint" },
	"[typescript]": { "editor.defaultFormatter": "dbaeumer.vscode-eslint" },
	"[typescriptreact]": { "editor.defaultFormatter": "dbaeumer.vscode-eslint" },

	// Markdown: markdownlint es el único que tienes con poder de auto-fix para MD022/MD032
	"[markdown]": {
		"editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
		"editor.formatOnSave": true
	},

	// ── Iconos del proyecto ───────────────────────────────────
	"workbench.iconTheme": "material-icon-theme",
	"material-icon-theme.activeIconPack": "react",
	"material-icon-theme.folders.theme": "specific",
	"material-icon-theme.folders.associations": {
		".agent": "Rules",
		".agents": "Rules",
		"(orchidarium)": "Seeders",
		"(shop)": "Cart",
		"actions": "Server",
		"bh1750": "Svg",
		"dashboard": "Benchmark",
		"firmware": "Core",
		"influxdb": "Database",
		"infrastructure": "Cluster",
		"ingest": "Aws",
		"login": "Secure",
		"migrations": "Prisma",
		"mosquitto-local": "Server",
		"mosquitto": "Server",
		"mqtt": "Aws",
		"new-account": "Secure",
		"orchidarium": "Layout",
		"ota": "Update",
		"persistence": "Database",
		"plant": "Seeders",
		"plants": "Seeders",
		"postgres": "Database",
		"product": "Seeders",
		"products": "Seeders",
		"relay_modules": "Pipe",
		"scheduler": "Job",
		"secrets": "Config",
		"sensors": "Environment",
		"store": "Store",
		"umqtt": "Aws",
		"weather-oracle": "Environment",
	},
	"search.useGlobalIgnoreFiles": true,
	"search.useParentIgnoreFiles": true,
}