# -------------------------------------------------------------------
# 🔐 CREDENCIALES MQTT (Roles del Sistema)
# -------------------------------------------------------------------
# Referencia de configuración: Ver infrastructure/mosquitto/config/passwd.template
# Definimos usuarios específicos para cada componente del sistema.
# Esto permite auditoría y control de acceso (ACLs) granular.

# ADMIN (MQTT Explorer)
MQTT_ROOT_USER=pristinoplant
MQTT_ROOT_PASS=tu-password-segura-admin

# BACKEND (Servicios Ingest y Scheduler)
# Usado por: services/ingest y services/scheduler
MQTT_USER_BACKEND=pristinoplant-backend
MQTT_PASS_BACKEND=tu-password-segura-backend

# FRONTEND (Cliente Web Next.js)
# Usado por: app (browser) vía WebSockets
MQTT_USER_FRONTEND=pristinoplant-web-client
MQTT_PASS_FRONTEND=tu-password-segura-frontend

# IOT DEVICES (Firmware ESP32)
# Usado por: firmware/sensors y firmware/relay_modules
MQTT_USER_IOT=pristinoplant-iot-device
MQTT_PASS_IOT=tu-password-segura-iot


# -------------------------------------------------------------------
# 🆔 Identificación de los Servicios del Backend
# -------------------------------------------------------------------
MQTT_CLIENT_ID_INGEST="Ingest"
MQTT_CLIENT_ID_SCHEDULER="Scheduler"


# -------------------------------------------------------------------
# 🐳 CONFIGURACIÓN DE INFRAESTRUCTURA (Docker Profiles)
# -------------------------------------------------------------------
# Selecciona el perfil activo. Solo UNO debe estar seleccionado.
#
# 💻 local      → Desarrollo en tu PC. Todo corre en Docker local.
# ☁️ cloud      → Producción en VPS. Infraestructura propia, sin límites.
# 🆓 serverless → Capas gratuitas (Neon + HiveMQ + InfluxDB Cloud).
# -------------------------------------------------------------------
COMPOSE_PROFILES=cloud


# -------------------------------------------------------------------
# 🗃️ CREDENCIALES COMPARTIDAS (PostgreSQL + InfluxDB)
# -------------------------------------------------------------------
# Usadas por los perfiles 'local' y 'cloud' (PostgreSQL en Docker).
# El perfil 'serverless' usa credenciales propias de Neon.
# -------------------------------------------------------------------

# PostgreSQL (Docker)
DB_USER=usuario_local
DB_PASSWORD=password_local
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pristinoplant

# InfluxDB (Docker)
# En Local: Generalo con 'docker exec -it influxdb-local influxdb3 create token --admin'
# En Cloud: Generalo con 'docker exec -it influxdb influxdb3 create token --admin'
INFLUX_TOKEN="tu-token-influxdb-admin"
INFLUX_ORG=PristinoPlant
INFLUX_BUCKET=telemetry
INFLUX_USER="Nombre Usuario"


# -------------------------------------------------------------------

#    📦 SECCIÓN DE CONEXIONES POR PERFIL

# -------------------------------------------------------------------


# -------------------------------------------------------------------
# ☁️ PERFIL CLOUD — Producción en VPS (Sin límites)
# -------------------------------------------------------------------
# PostgreSQL, InfluxDB y Mosquitto corren como contenedores Docker
# dentro del VPS. Los servicios se conectan por red interna Docker.
# Puertos 5432 y 8181 están expuestos para Vercel.
# -------------------------------------------------------------------

# Base de Datos (Red Interna Docker)
# ⚠️ IMPORTANTE: No uses interpolación de variables (${...}) en las URLs de conexión para evitar fallos con la CLI de Prisma.
DATABASE_URL_CLOUD=postgresql://usuario_local:password_local@postgres:5432/pristinoplant?schema=public
DATABASE_URL_CLOUD_UNPOOLED=postgresql://usuario_local:password_local@postgres:5432/pristinoplant?schema=public

# MQTT (Red Interna Docker — Mosquitto propio)
MQTT_BROKER_URL_CLOUD=mqtt://mosquitto:1883

# InfluxDB (Red Interna Docker)
INFLUX_URL_CLOUD=https://influxdb:8181


# -------------------------------------------------------------------
# 💻 PERFIL LOCAL — Desarrollo en tu PC
# -------------------------------------------------------------------
# Idéntico al perfil cloud pero con nombres DNS con sufijo '-local'.
# ⚠️ NUNCA funcionará en producción (no es accesible desde internet).
# -------------------------------------------------------------------

# Base de Datos (Red Interna Docker)
DATABASE_URL_LOCAL=postgresql://usuario_local:password_local@postgres-local:5432/pristinoplant?schema=public

# MQTT (Red Interna Docker)
MQTT_BROKER_URL_LOCAL=mqtt://mosquitto-local:1883

# InfluxDB (Red Interna Docker)
INFLUX_URL_LOCAL=http://influxdb-local:8181


# -------------------------------------------------------------------
# 🆓 PERFIL SERVERLESS — Capas Gratuitas (Con Límites)
# -------------------------------------------------------------------
# Sin contenedores propios. Conecta a proveedores externos:
#   - PostgreSQL → Neon (Límite: 100h computo/mes)
#   - MQTT       → HiveMQ Cloud
#   - InfluxDB   → InfluxDB Cloud AWS (Límite: 30 días de datos)
#
# ⚠️ PRECAUCIÓN: El polling del scheduler (checkPendingTasks) ejecuta
#    5 queries cada 60s (~216K queries/mes). Con Neon, esto puede
#    agotar la cuota rápidamente. Considerar aumentar el intervalo.
# -------------------------------------------------------------------

# -------------------------------------------------------------------
# 📄 Guía de Configuración de la Base de Datos (Vercel Neon)
# -------------------------------------------------------------------
# 1. Ve a: https://console.neon.tech/app/projects (o Vercel > Storage > Neon)
# 2. Selecciona tu proyecto y asegúrate de estar en la rama "main".
# 3. Ve al Dashboard y haz clic en "Connect".
# 3. Selecciona "Connection string".
# 4. CONFIGURACIÓN DE URLS (Necesitas dos variables para Prisma + Serverless):
#    A) DATABASE_URL (Para la App - Pooled):
#       - Activa el interruptor "Connection pooling".
#       - Esta URL gestiona miles de conexiones simultáneas.
#    B) DATABASE_URL_UNPOOLED (Para Migraciones - Unpooled):
#       - Desactiva el interruptor "Connection pooling".
#       - Esta URL se usa solo para `prisma migrate deploy`.
# 5. AJUSTES CRÍTICOS (Correcciones aplicadas):
#    - SSL: Debe terminar en "?sslmode=require".
#    - Latencia: Agrega "&connect_timeout=30" al final de DATABASE_URL para evitar
#      errores de conexión desde redes lentas o arranques en frío.
#    - Latencia del pool: Agrega "&pool_timeout=30"
#      Si el pool de conexiones está lleno, espera 30 segundos a que se libere una.
# -------------------------------------------------------------------

# Neon PostgreSQL
# Guía: https://console.neon.tech/app/projects → Connect → Connection string
# Pooled (para la App):
DATABASE_URL_SERVERLESS=postgresql://usuario:pass@host-pooler.neon.tech/neondb?sslmode=require&connect_timeout=60&pool_timeout=60
# Unpooled (para Migraciones):
DATABASE_URL_SERVERLESS_UNPOOLED=postgresql://usuario:pass@host.neon.tech/neondb?sslmode=require&connect_timeout=60&pool_timeout=60
DB_HOST_SERVERLESS=host-pooler.neon.tech
DB_USER_SERVERLESS=neondb_owner

# HiveMQ Cloud
MQTT_BROKER_URL_SERVERLESS=mqtts://tu-cluster.hivemq.cloud:8883

# InfluxDB Cloud (AWS — Retención máxima 30 días)
# Guía: https://us-east-1-1.aws.cloud2.influxdata.com → API Tokens
INFLUX_URL_SERVERLESS=https://us-east-1-1.aws.cloud2.influxdata.com
INFLUX_TOKEN_SERVERLESS="tu-token-influxdb-cloud"


# -------------------------------------------------------------------
#
#    📱 APP NEXT.JS — Configuración del Frontend
#
# -------------------------------------------------------------------
# Estas variables las consume la app Next.js en Vercel (producción).
# Configura según el perfil que estés utilizando en el backend.
# -------------------------------------------------------------------

# -------------------------------------------------------------------
# 1. Base de Datos
# -------------------------------------------------------------------
# >> Perfil CLOUD: Apuntar al VPS (IP/dominio público) <<
# ⚠️ IMPORTANTE: Reemplaza las credenciales directamente en la URL. NO uses variables interpoladas como ${DB_USER}.
DATABASE_URL=postgresql://usuario_vps:password_vps@tu-dominio-vps.com:5432/pristinoplant?schema=public&sslmode=require&connect_timeout=30
DATABASE_URL_UNPOOLED=postgresql://usuario_vps:password_vps@tu-dominio-vps.com:5432/pristinoplant?schema=public&sslmode=require&connect_timeout=30

# >> Perfil LOCAL: Apuntar al Docker de tu PC <<
# DATABASE_URL=postgresql://usuario_local:password_local@localhost:5432/pristinoplant?schema=public
# DATABASE_URL_UNPOOLED=postgresql://usuario_local:password_local@localhost:5432/pristinoplant?schema=public

# >> Perfil SERVERLESS: Apuntar a Neon <<
# DATABASE_URL=postgresql://usuario:pass@host-pooler.neon.tech/neondb?sslmode=require&connect_timeout=60&pool_timeout=60
# DATABASE_URL_UNPOOLED=postgresql://usuario:pass@host.neon.tech/neondb?sslmode=require&connect_timeout=60&pool_timeout=60

# -------------------------------------------------------------------
# 2. MQTT (Cliente Web)
# -------------------------------------------------------------------
NEXT_PUBLIC_MQTT_BASE_TOPIC=PristinoPlant
NEXT_PUBLIC_MQTT_USERNAME=pristinoplant-web-client
NEXT_PUBLIC_MQTT_PASSWORD=tu-password-segura-frontend

# >> Perfil CLOUD: Mosquitto propio en el VPS <<
NEXT_PUBLIC_MQTT_PROTOCOL=wss
NEXT_PUBLIC_MQTT_BROKER=tu-broker-mosquitto
NEXT_PUBLIC_MQTT_PORT=8884

# >> Perfil LOCAL: Mosquitto Docker local <<
# NEXT_PUBLIC_MQTT_PROTOCOL=ws
# NEXT_PUBLIC_MQTT_BROKER=localhost
# NEXT_PUBLIC_MQTT_PORT=9001

# >> Perfil SERVERLESS: HiveMQ Cloud <<
# NEXT_PUBLIC_MQTT_PROTOCOL=wss
# NEXT_PUBLIC_MQTT_BROKER=tu-cluster.hivemq.cloud
# NEXT_PUBLIC_MQTT_PORT=8884

# -------------------------------------------------------------------
# 3. InfluxDB
# -------------------------------------------------------------------
# >> Perfil CLOUD: InfluxDB en el VPS <<
INFLUX_URL=https://tu-dominio-vps.com:8181

# >> Perfil LOCAL: InfluxDB Docker local <<
# INFLUX_URL=http://localhost:8181

# >> Perfil SERVERLESS: InfluxDB Cloud AWS (30 días) <<
# INFLUX_URL=https://us-east-1-1.aws.cloud2.influxdata.com

# -------------------------------------------------------------------
# NOTA SOBRE 'DATABASE_URL_UNPOOLED':
# - En Neon (serverless): Es OBLIGATORIA para migraciones (sin Pooler).
# - En Docker (cloud/local): No existe "Pooler", ambas URLs son idénticas.
# -------------------------------------------------------------------