generator client {
  provider               = "prisma-client"
  output                 = "../src/generated/prisma"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
  moduleFormat           = "esm"
  runtime                = "nodejs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          Role      @default(USER)
  accounts      Account[]
  sessions      Session[]
  taskEvents    TaskEventLog[]
  notifications Notification[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Genus {
  id      String    @id @default(uuid())
  name    String    @unique
  type    PlantType
  species Species[]
}

model Species {
  id          String           @id @default(uuid())
  name        String           @unique
  slug        String           @unique
  description String?
  genusId     String
  plants      Plant[]
  variants    ProductVariant[]
  genus       Genus            @relation(fields: [genusId], references: [id], onDelete: Cascade)
  images      SpeciesImage[]

  @@index([genusId])
}

model ProductVariant {
  id        String   @id @default(uuid())
  size      PotSize
  price     Int
  quantity  Int      @default(0)
  available Boolean  @default(false)
  speciesId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  species   Species  @relation(fields: [speciesId], references: [id], onDelete: Cascade)

  @@unique([speciesId, size])
  @@index([speciesId])
}

model SpeciesImage {
  id        String  @id @default(uuid())
  url       String  @unique
  speciesId String
  species   Species @relation(fields: [speciesId], references: [id], onDelete: Cascade)

  @@index([speciesId])
}

model Location {
  id     String    @id @default(uuid())
  zone   ZoneType
  table  TableType
  plants Plant[]

  @@unique([zone, table])
}

model FloweringEvent {
  id        String    @id @default(uuid())
  startDate DateTime
  endDate   DateTime?
  plantId   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  plant     Plant     @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@index([plantId])
}

model Plant {
  id             String           @id @default(uuid())
  pottingDate    DateTime?
  currentSize    PotSize
  status         PlantStatus      @default(AVAILABLE)
  speciesId      String
  locationId     String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  FloweringEvent FloweringEvent[]
  pestSightings  PestSighting[]
  location       Location?        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  species        Species          @relation(fields: [speciesId], references: [id], onDelete: Cascade)

  @@index([speciesId])
  @@index([locationId])
  @@index([status])
}

model Agrochemical {
  id                  String               @id @default(uuid())
  name                String               @unique
  description         String
  type                AgrochemicalType
  purpose             AgrochemicalPurpose
  preparation         String
  fertilizationCycles FertilizationCycle[]
  phytosanitaryCycles PhytosanitaryCycle[]
  tasksExecuted       TaskLog[]
}

model FertilizationProgram {
  id              String               @id @default(uuid())
  name            String               @unique
  weeklyFrequency Int
  schedules       AutomationSchedule[]
  productsCycle   FertilizationCycle[]
}

model FertilizationCycle {
  id             String               @id @default(uuid())
  sequence       Int
  agrochemicalId String
  programId      String
  agrochemical   Agrochemical         @relation(fields: [agrochemicalId], references: [id], onDelete: Cascade)
  program        FertilizationProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, sequence])
}

model PhytosanitaryProgram {
  id               String               @id @default(uuid())
  name             String               @unique
  monthlyFrequency Int
  schedules        AutomationSchedule[]
  productsCycle    PhytosanitaryCycle[]
}

model PhytosanitaryCycle {
  id             String               @id @default(uuid())
  sequence       Int
  agrochemicalId String
  programId      String
  agrochemical   Agrochemical         @relation(fields: [agrochemicalId], references: [id], onDelete: Cascade)
  program        PhytosanitaryProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, sequence])
}

model AutomationSchedule {
  id                     String                @id @default(uuid())
  name                   String                @unique
  description            String?
  isEnabled              Boolean               @default(true)
  purpose                TaskPurpose
  cronTrigger            String
  intervalDays           Int                   @default(1)
  durationMinutes        Int                   @default(10)
  zones                  ZoneType[]
  fertilizationProgramId String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  phytosanitaryProgramId String?
  fertilizationProgram   FertilizationProgram? @relation(fields: [fertilizationProgramId], references: [id])
  phytosanitaryProgram   PhytosanitaryProgram? @relation(fields: [phytosanitaryProgramId], references: [id])
  taskLogs               TaskLog[]
}

model TaskLog {
  id               String              @id @default(uuid())
  scheduledAt      DateTime
  executedAt       DateTime            @default(now())
  status           TaskStatus          @default(PENDING)
  source           TaskSource          @default(MANUAL)
  purpose          TaskPurpose
  zones            ZoneType[]
  duration         Int
  notes            String?
  agrochemicalId   String?
  scheduleId       String?
  actualStartAt    DateTime?
  completedMinutes Int                 @default(0)
  events           TaskEventLog[]
  notifications    Notification[]
  agrochemical     Agrochemical?       @relation(fields: [agrochemicalId], references: [id])
  schedule         AutomationSchedule? @relation(fields: [scheduleId], references: [id])

  @@index([scheduledAt])
  @@index([status])
}

model TaskEventLog {
  id        String     @id @default(uuid())
  status    TaskStatus
  timestamp DateTime   @default(now())
  notes     String?
  taskId    String
  userId    String?
  task      TaskLog    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User?      @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([timestamp])
}

model DailyEnvironmentStat {
  id                  String   @id @default(uuid())
  date                DateTime @db.Date
  zone                ZoneType
  avgTemperature      Float?
  minTemperature      Float?
  maxTemperature      Float?
  avgHumidity         Float?
  minHumidity         Float?
  maxHumidity         Float?
  lightDurationHours  Float
  totalRainDuration   Int
  createdAt           DateTime @default(now())
  avgIlluminance      Float?
  maxIlluminance      Float?
  /// Temperatura promedio diurna (08:00–16:00 hora local)
  avgTempDay          Float?
  /// Temperatura promedio nocturna (20:00–06:00 hora local)
  avgTempNight        Float?
  /// Diferencial Térmico Día-Noche (°C). Ideal Cattleya: 5-8°C para inducir floración.
  dif                 Float?
  /// Daily Light Integral (mol/m²/d) — Integral de luz fotosintética acumulada en el fotoperiodo.
  /// Lux → PPFD (×0.018) → DLI. Ideal para Cattleya: 12-15 mol/m²/d.
  dli                 Float?
  /// Horas con HR > 85% en período nocturno — indicador de riesgo de Botrytis/hongos
  highHumidityHours   Float?
  /// Balance hídrico: minutos totales de riego ejecutado en el día
  irrigationMinutes   Int?
  maxHumTime          String?
  maxIllumTime        String?
  maxTempTime         String?
  minHumTime          String?
  minIllumTime        String?
  minIlluminance      Float?
  minTempTime         String?
  /// Balance hídrico: minutos totales de nebulización ejecutada en el día
  nebulizationMinutes Int?
  /// Conteo total de eventos de agua (riego + lluvia + nebulización)
  totalWaterEvents    Int?
  /// Déficit de Presión de Vapor promedio diurno (kPa). Ideal orquídeas: 0.8–1.2 kPa.
  vpdAvg              Float?
  vpdMax              Float?
  vpdMin              Float?
  /// Clasificación del tipo de día: EXTREMELY_SUNNY, SUNNY, TEMPERATE, OVERCAST, RAINY
  dayType             String?

  @@unique([date, zone])
  @@index([date])
}

model DeviceLog {
  id        String       @id @default(uuid())
  device    String
  status    DeviceStatus
  timestamp DateTime     @default(now())
  notes     String

  @@index([device])
  @@index([timestamp])
}

model WeatherForecast {
  id           String           @id @default(uuid())
  timestamp    DateTime
  temperature  Float
  humidity     Float
  pressure     Float?
  precipProb   Float            @default(0)
  condition    WeatherCondition @default(UNKNOWN)
  windSpeed    Float?
  source       String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  soilMoisture Float?
  soilTemp     Float?

  @@unique([timestamp, source])
  @@index([timestamp])
}

model WeatherAlert {
  id          String    @id @default(uuid())
  type        String
  severity    String
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([startsAt])
}

model Pest {
  id          String         @id @default(uuid())
  name        String         @unique
  description String?
  category    PestCategory
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  sightings   PestSighting[]
}

model PestSighting {
  id         String   @id @default(uuid())
  pestId     String?
  pestName   String?
  zone       ZoneType
  severity   Severity @default(LOW)
  notes      String?
  capturedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  plantId    String?
  pest       Pest?    @relation(fields: [pestId], references: [id])
  plant      Plant?   @relation(fields: [plantId], references: [id])

  @@index([zone])
  @@index([pestId])
  @@index([plantId])
}

enum DeviceStatus {
  ONLINE
  OFFLINE
}

enum Role {
  USER
  ADMIN
}

enum ZoneType {
  ZONA_A
  ZONA_B
  ZONA_C
  ZONA_D
  EXTERIOR
}

enum TableType {
  MESA_1
  MESA_2
  MESA_3
  MESA_4
  MESA_5
  MESA_6
}

enum PlantType {
  ADENIUM_OBESUM
  BROMELIAD
  CACTUS
  ORCHID
  SUCCULENT
}

enum PotSize {
  NRO_5
  NRO_7
  NRO_10
  NRO_14
}

enum PlantStatus {
  AVAILABLE
  MOTHER
}

enum TaskStatus {
  CANCELLED
  COMPLETED
  CONFIRMED
  FAILED
  IN_PROGRESS
  PENDING
  SKIPPED
  WAITING_CONFIRMATION
  AUTHORIZED
  DISPATCHED
  ACKNOWLEDGED
  EXPIRED
}

enum TaskSource {
  MANUAL
  DEFERRED
  ROUTINE
  INFERENCE
}

enum TaskPurpose {
  IRRIGATION
  FERTIGATION
  FUMIGATION
  HUMIDIFICATION
  SOIL_WETTING
}

enum AgrochemicalType {
  FERTILIZANTE
  FITOSANITARIO
}

enum AgrochemicalPurpose {
  DESARROLLO
  FLORACION
  MANTENIMIENTO
  ACARICIDA
  BACTERICIDA
  FUNGICIDA
  INSECTICIDA
}

enum WeatherCondition {
  CLEAR
  CLOUDY
  RAIN
  STORM
  FOG
  SNOW
  UNKNOWN
}

enum PestCategory {
  INSECT
  FUNGUS
  BACTERIA
  MITE
  VIRUS
  OTHER
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}
enum NotificationType {
  MAINTENANCE_REMINDER
  AGROCHEMICAL_CONFIRM
  SYSTEM_ALERT
  TASK_STATUS
}

enum NotificationStatus {
  UNREAD
  READ
  DISMISSED
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Notification {
  id           String               @id @default(uuid())
  type         NotificationType
  title        String
  description  String?
  status       NotificationStatus   @default(UNREAD)
  priority     NotificationPriority @default(NORMAL)
  taskId       String?
  task         TaskLog?             @relation(fields: [taskId], references: [id])
  targetUserId String?
  targetUser   User?                @relation(fields: [targetUserId], references: [id])
  createdAt    DateTime             @default(now())
  readAt       DateTime?

  @@index([status])
  @@index([createdAt])
  @@index([targetUserId])
}
